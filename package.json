{
  "name": "school-webpage",
  "version": "1.0.0",
  "description": "Local School Webpage Server",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"node backend/server.js\" \"http-server -a localhost -p 8000 -c-1 -o --proxy http://localhost:5000\"",
    "seed": "node prisma/seed.js",
    "check-db": "node check-db.js",
    "full-validation": "node full-validation.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "concurrently": "^9.2.1",
    "http-server": "^14.1.1",
    "prisma": "5.22.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@supabase/supabase-js": "^2.105.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^8.0.10",
    "xlsx": "^0.18.5"
  }
}
