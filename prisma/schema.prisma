generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Student {
  id           Int     @id @default(autoincrement())
  student_code String? @unique
  name         String
  class        String
  medium       String
  parent_name  String?
  roll_no      String?
  photo_url    String?

  @@map("students")
}

model Teacher {
  id          Int      @id @default(autoincrement())
  name        String
  subject     String
  medium      String
  designation String?
  experience  String?
  category    String?
  photo_url   String?
  joined_date DateTime @default(now())

  @@map("teachers")
}

model Gallery {
  id          Int       @id @default(autoincrement())
  image_url   String?
  category    String?
  description String?
  upload_date DateTime? @default(now())

  @@map("gallery")
}

model Notice {
  id          Int       @id @default(autoincrement())
  title       String?
  description String?
  date        DateTime?

  @@map("notices")
}

model Alumni {
  id         Int     @id @default(autoincrement())
  name       String?
  batch_year String?
  profession String?
  photo_url  String?

  @@map("alumni")
}

model Attendance {
  id           Int       @id @default(autoincrement())
  student_code String?
  class        String?
  medium       String?
  period       String?
  subject      String?
  teacher_name String?
  date         DateTime?
  status       String?

  @@map("attendance")
}

model Marks {
  id           Int     @id @default(autoincrement())
  student_code String?
  class        String?
  medium       String?
  subject      String?
  exam_type    String?
  marks        Int?
  total        Int?

  @@map("marks")
}


model CertificateRequest {
  id               Int       @id @default(autoincrement())
  student_code     String?
  certificate_type String?
  status           String?   @default("Pending")
  request_date     DateTime? @default(now())

  @@map("certificate_requests")
}

model ClassSubject {
  id      Int    @id @default(autoincrement())
  class   String
  medium  String
  subject String

  @@unique([class, medium, subject])
  @@map("class_subjects")
}

